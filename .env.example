# ========== Qdrant 配置 ==========
# 运行模式：local（本地）或 remote（远程服务器）
QDRANT_MODE=local

# 本地模式下的存储路径（仅当 QDRANT_MODE=local 时使用）
# QDRANT_PATH 会自动设置为 storage/qdrant

# 远程模式配置（仅当 QDRANT_MODE=remote 时使用）
# QDRANT_HOST=qdrant.example.com
# QDRANT_PORT=6333
# QDRANT_API_KEY=your-api-key-here

# ========== Langfuse 监控配置 ==========
# 从 https://cloud.langfuse.com 获取你的密钥
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
